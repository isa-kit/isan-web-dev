{
  "app": {
    "title": "Docs",
    "primaryColor": "#00897B",
    "theme": "sepia"
  },
  "nav": [
    {
      "id": "pages",
      "label": "Documents",
      "icon": "menu_book",
      "screen": "pages"
    },
    {
      "id": "all",
      "label": "All",
      "icon": "list",
      "screen": "all"
    }
  ],
  "screens": {
    "pages": {
      "title": "Documents",
      "body": {
        "type": "explorer",
        "railMode": "collapsible",
        "table": "pages",
        "nameColumn": "title",
        "kindColumn": "kind",
        "parentColumn": "parentId",
        "title": "Documents",
        "fileIcon": "doc",
        "newFileLabel": "New document",
        "newFolderLabel": "New folder",
        "detail": {
          "type": "pages",
          "table": "pages",
          "nameColumn": "title",
          "parentColumn": "parentId",
          "orderColumn": "order",
          "kindColumn": "kind",
          "pageValue": "page",
          "pageLabel": "Page",
          "detail": {
            "type": "notepad",
            "table": "pages",
            "column": "body",
            "titleColumn": "title",
            "placeholder": "Write your document… use # headings, - bullets, **bold**."
          }
        }
      }
    },
    "all": {
      "title": "All documents",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Your documents, newest edit first. A document's pages live inside it — open it to see them."
          },
          {
            "type": "cards",
            "table": "pages",
            "title": "title",
            "emptyIcon": "note_add",
            "emptyTitle": "No documents yet",
            "emptyText": "Start your first document and its pages will live inside it.",
            "filter": {
              "column": "parentId",
              "empty": true
            },
            "sort": {
              "column": "updatedAt",
              "dir": "desc"
            },
            "action": {
              "fn": "editRow"
            }
          }
        ]
      }
    },
    "solo": {
      "title": "Document",
      "body": {
        "type": "explorer",
        "table": "pages",
        "nameColumn": "title",
        "kindColumn": "kind",
        "parentColumn": "parentId",
        "fileIcon": "doc",
        "newFileLabel": "New document",
        "railMode": "none",
        "autoSelectFirst": true,
        "startBlank": true,
        "detail": {
          "type": "notepad",
          "table": "pages",
          "column": "body",
          "titleColumn": "title",
          "placeholder": "Write your document… use # headings, - bullets, **bold**."
        }
      }
    }
  }
}