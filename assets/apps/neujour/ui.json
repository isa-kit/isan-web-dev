                      "type": "button",
                      "label": "Connect two people",
                      "icon": "link",
                      "action": {
                        "fn": "addRow",
                        "args": {
                          "table": "connections"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "canvas",
                  "nodesTable": "people",
                  "edgesTable": "connections",
                  "labelColumn": "name",
                  "xColumn": "x",
                  "yColumn": "y",
                  "fromColumn": "from",
                  "toColumn": "to",
                  "edgeLabelColumn": "label",
                  "height": 380,
                  "action": {
                    "fn": "editRow"
                  }
                },
