  "screens": {
    "journal": {
      "title": "Journal",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Your journal — capture a moment, then tap any entry to add people, events, tags, or independent parts. Edits autosave; Undo/Redo live in the entry view. Filter by mood or tag below."
          },
          {
            "type": "button",
            "label": "New entry",
            "icon": "add",
            "action": {
              "fn": "addRow",
              "args": {
                "table": "entries",
                "values": {}
              }
            }
          },
          {
            "type": "row",
            "wrap": true,
            "children": [
              {
                "type": "button",
                "label": "Reflection",
                "action": {
                  "fn": "setFilter",
                  "args": {
                    "table": "entries",
                    "column": "tags",
                    "value": "tag_reflection"
                  }
                }
              },
              {
                "type": "button",
                "label": "Work",
                "action": {
                  "fn": "setFilter",
                  "args": {
                    "table": "entries",
                    "column": "tags",
                    "value": "tag_work"
                  }
                }
              },
              {
                "type": "button",
                "label": "Family",
                "action": {
                  "fn": "setFilter",
                  "args": {
                    "table": "entries",
                    "column": "tags",
                    "value": "tag_family"
                  }
                }
              },
              {
                "type": "button",
                "label": "All",
                "action": {
                  "fn": "setFilter",
                  "args": {
                    "table": "entries",
                    "column": "tags",
                    "value": ""
                  }
                }
              }
            ]
          },
          {
            "type": "cards",
            "emptyIcon": "note_add",
            "emptyTitle": "Your journal is empty",
            "emptyText": "Capture your first moment — tap New entry to start writing today.",
            "emptyAction": {
              "fn": "addRow",
              "args": {
                "table": "entries",
                "values": {}
              }
            },
            "emptyActionLabel": "New entry",
            "confirmDelete": true,
            "table": "entries",
            "groupBy": "mood",
            "groupOrder": [
              "great",
              "good",
              "ok",
              "low",
              "rough"
            ],
            "groupByOptions": [
              {
                "label": "Mood",
                "column": "mood"
              },
              {
                "label": "Tag",
                "column": "tags"
              },
              {
                "label": "People",
                "column": "people"
              }
            ],
            "sort": {
              "column": "date",
              "dir": "desc"
            },
            "title": "title",
            "subtitle": "body",
            "tags": [
              {
                "column": "mood",
                "colors": {
                  "great": "green",
                  "good": "teal",
                  "ok": "blue",
                  "low": "amber",
                  "rough": "red"
                }
              },
              {
                "column": "date"
              },
              {
                "column": "time"
              }
            ],
            "collapsible": true,
            "recent": 8,
            "expandable": true,
            "expandFields": [
              {
                "column": "date",
                "label": "Date"
              },
              {
                "column": "time",
                "label": "Time"
              },
              {
                "column": "tz",
                "label": "Time zone"
              },
              {
                "column": "mood",
                "label": "Mood"
              },
              {
                "column": "people",
                "label": "People"
              },
              {
                "column": "events",
                "label": "Events"
              },
              {
                "column": "tags",
                "label": "Tags"
              },
              {
                "column": "places",
                "label": "Places"
              },
              {
                "column": "quantity",
                "label": "Quantity"
              },
              {
                "column": "body",
                "label": "Full entry"
              }
            ],
            "open": "Open entry",
            "action": {
              "fn": "editRow"
            }
          }
        ]
      }
    },
    "calendar": {
      "title": "Calendar",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Your entries by date. Tap an entry to open it; tap an empty day to start a new entry already dated to that day. Use the arrows to look back."
          },
          {
            "type": "row",
            "wrap": true,
            "children": [
              {
                "type": "text",
                "style": "caption",
                "value": "Week starts on:"
              },
              {
                "type": "button",
                "label": "Monday",
                "action": {
                  "fn": "setField",
                  "args": {
                    "table": "prefs",
                    "id": "prefs",
                    "column": "weekStart",
                    "value": "monday"
                  }
                }
              },
              {
                "type": "button",
                "label": "Sunday",
                "action": {
                  "fn": "setField",
                  "args": {
                    "table": "prefs",
                    "id": "prefs",
                    "column": "weekStart",
                    "value": "sunday"
                  }
                }
              }
            ]
          },
          {
            "type": "calendar",
            "table": "entries",
            "titleColumn": "title",
            "scroll": true,
            "dateColumns": [
              "date"
            ],
            "dateColumn": "date",
            "weekStartTable": "prefs",
            "weekStartColumn": "weekStart",
            "action": {
              "fn": "editRow"
            },
            "addAction": {
              "fn": "addRow",
              "args": {
                "table": "entries",
                "values": {}
              }
            }
          }
        ]
      }
    },
    "timeline": {
      "title": "Timeline",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Your days. Write an overall note for a day, and see every entry grouped under the day it happened."
          },
          {
            "type": "button",
            "label": "Day note",
            "icon": "edit_calendar",
            "action": {
              "fn": "addRow",
              "args": {
                "table": "days"
              }
            }
          },
          {
            "type": "cards",
            "table": "days",
            "confirmDelete": true,
            "sort": {
              "column": "date",
              "dir": "desc"
            },
            "title": "date",
            "subtitle": "summary",
            "tags": [
              {
                "column": "mood",
                "colors": {
                  "great": "green",
                  "good": "teal",
                  "ok": "blue",
                  "low": "amber",
                  "rough": "red"
                }
              }
            ],
            "expandable": true,
