            "type": "text",
            "style": "caption",
            "value": "Entries, grouped by day."
          },
          {
            "type": "cards",
            "emptyIcon": "edit_note",
            "emptyTitle": "No entries yet",
            "emptyText": "Write your first entry -- today is a good place to start.",
            "emptyAction": {"fn": "addRow", "args": {"table": "entries", "values": {}}},
            "emptyActionLabel": "New entry",
            "table": "entries",
            "confirmDelete": true,
            "groupBy": "date",
            "groupByOptions": [
              {
                "label": "Day",
                "column": "date"
              },
              {
                "label": "Mood",
                "column": "mood"
              }
            ],
            "sort": {
              "column": "date",
              "dir": "desc"
            },
            "title": "title",
            "subtitle": "body",
            "tags": [
              {
                "column": "date"
              },
              {
                "column": "time"
              },
              {
                "column": "mood",
                "colors": {
                  "great": "green",
                  "good": "teal",
                  "ok": "blue",
                  "low": "amber",
                  "rough": "red"
                }
              }
            ],
            "search": true,
            "searchColumns": [
              "title",
              "body"
            ],
            "expandable": true,
            "expandFields": [
              {
                "column": "date",
                "label": "Date"
              },
              {
                "column": "time",
                "label": "Time"
              },
              {
                "column": "tz",
                "label": "Time zone"
              },
              {
                "column": "mood",
                "label": "Mood"
              },
              {
                "column": "people",
                "label": "People"
              },
              {
                "column": "tags",
                "label": "Tags"
              },
              {
                "column": "body",
                "label": "Full entry"
              }
            ],
            "open": "Open entry",
            "action": {
              "fn": "editRow"
            }
          }
        ]
      }
    },
    "customize": {
      "title": "Customize",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Shape Neujour to fit you. Add or remove data types (e.g. drop Places), and add/edit/remove attributes on any type — pick each one's kind: text, rich text, number, date, yes/no, options (with your own values, like colors), a link to another type, or attachments. Changes apply instantly and sync."
          },
          {
            "type": "schemaeditor"
          }
        ]
      }
    },
    "trends": {
      "title": "Trends",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Two lenses: WHAT MOVES YOU — a multivariable fit over your entries (people, tags, places, feelings vs. your Emotion score), computed on this device; and a single-metric trend + forecast from measurements. Set Emotion (0–5) on entries to feed the first."
          },
          {
            "type": "insights",
            "table": "entries",
            "targetColumn": "emotion",
            "featureRefs": [
              "people",
              "tags",
              "places"
            ],
            "featuresTable": "feelings",
            "featureNameColumn": "name",
            "featureValueColumn": "score",
            "featureScaleColumn": "outOf",
            "featureLinkColumn": "entry",
            "label": "What makes you happy (and what doesn’t)",
            "topN": 8
          },
          {
            "type": "divider"
          },
          {
            "type": "button",
            "label": "Add measurement",
            "icon": "add",
            "action": {
              "fn": "addRow",
              "args": {
                "table": "measurements",
                "values": {
                  "metric": "energy"
                }
              }
            }
          },
          {
            "type": "regression",
            "table": "measurements",
            "xColumn": "date",
            "yColumn": "value",
            "height": 220,
            "filterColumn": "metric"
          },
          {
            "type": "table",
            "table": "measurements",
            "columns": [
              "date",
              "metric",
              "value"
            ],
            "height": 240,
            "action": {
              "fn": "editRow"
            }
          }
        ]
      }
    },
    "feelings": {
      "title": "Feelings",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Named scores, on your own scale: sad 3.5/5, bored 1/5, motivated 10/10. Log one any time; link it to an entry to decode that day’s overall emotion into its parts."
          },
          {
            "type": "row",
            "children": [
              {
                "type": "stat",
                "table": "feelings",
                "agg": "count",
                "label": "Logged"
              },
              {
                "type": "stat",
                "table": "feelings",
                "agg": "avg",
                "valueColumn": "score",
                "label": "Average score",
                "color": "purple"
              }
            ]
          },
          {
            "type": "button",
            "label": "Log a feeling",
            "icon": "add",
            "action": {
              "fn": "addRow",
              "args": {
                "table": "feelings",
                "values": {
                  "outOf": "5"
                }
              }
            }
          },
          {
            "type": "cards",
            "emptyIcon": "mood",
            "emptyTitle": "No feelings logged",
            "emptyText": "Track how you feel to see patterns over time.",
            "emptyAction": {"fn": "addRow", "args": {"table": "feelings", "values": {"outOf": "5"}}},
            "emptyActionLabel": "Add",
            "confirmDelete": true,
            "table": "feelings",
            "title": "name",
            "subtitle": "score",
            "tags": [
              {
                "column": "outOf"
              },
              {
                "column": "date"
              }
            ],
            "search": true,
            "searchColumns": [
              "name",
              "note"
            ],
            "sortColumn": "date",
            "sortDir": "desc",
            "expandable": true,
            "expandFields": [
              {
                "column": "score",
                "label": "Score"
              },
              {
                "column": "outOf",
                "label": "Out of"
              },
              {
                "column": "note",
                "label": "Note"
              },
              {
                "column": "entry",
                "label": "Entry"
              }
            ],
            "action": {
              "fn": "editRow"
            }
          }
        ]
      }
    },
    "atlas": {
      "title": "Atlas",
      "body": {
        "type": "segments",
        "segments": [
          {
            "label": "People",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
