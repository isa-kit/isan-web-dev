                  "open": "Open",
                  "action": {
                    "fn": "editRow"
                  }
                }
              ]
            }
          },
          {
            "label": "Events",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "Moments and occasions you've journaled about. Tap to edit or add a new one."
                },
                {
                  "type": "button",
                  "label": "New event",
                  "icon": "add",
                  "action": {
                    "fn": "addRow",
