          },
          {
            "label": "Tags",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "Tags help you find themes across entries. Tap to rename or recolor."
                },
                {
                  "type": "button",
