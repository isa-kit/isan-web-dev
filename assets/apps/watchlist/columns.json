    },
    {
      "name": "tags",
      "type": "text",
      "label": "Tags"
    },
    {
      "name": "notes",
      "type": "text",
      "label": "Notes"
    },
    {
      "name": "recReason",
      "type": "text",
      "label": "Why recommended",
