    },
    {
      "name": "url",
      "type": "uri",
      "label": "URL"
    },
    {
      "name": "topic",
      "type": "enum",
      "label": "Topic",
      "options": [
        "Science",
        "Tech",
        "Cooking",
        "Music",
        "Other"
      ]
    },
    {
