{
  "app": {
    "title": "Dispatch",
    "primaryColor": "#0F766E",
    "theme": "minimal",
    "autosave": false,
    "liveSeconds": 3
  },
  "nav": [
    { "id": "thread", "label": "Projects", "icon": "account_tree", "screen": "thread" },
    { "id": "people", "label": "People", "icon": "group", "screen": "people" },
    { "id": "howto", "label": "How", "icon": "help_outline", "screen": "howto" }
  ],
  "screens": {
    "thread": {
      "title": "Dispatch",
      "body": {
        "type": "explorer",
        "table": "entries",
        "nameColumn": "title",
        "kindColumn": "type",
        "folderValue": "group",
        "fileValue": "note",
        "edgesTable": "relations",
        "edgeFrom": "fromId",
        "edgeTo": "toId",
        "edgeType": "type",
        "containsType": "contains",
        "sharedBadge": true,
        "dragReparent": true,
        "recursive": true,
        "orderColumn": "order",
        "title": "Projects",
        "railTitle2": "Tasks",
        "twoLevel": true,
        "treeRail": true,
        "showChildCounts": true,
        "childCountLabel": "log entry|log entries",
        "breadcrumb": true,
        "railWidth1": 230,
        "railWidth2": 290,
        "autoSelectFirstChild": true,
        "menuActions": [
          { "label": "Export project…", "folderOnly": true, "action": { "fn": "exportProject" } },
          { "label": "Import project here…", "folderOnly": true, "action": { "fn": "importProject" } }
        ],
        "railWidth": 300,
        "railMode": "collapsible",
        "autoSelectFirst": true,
        "iconColumn": "type",
        "fileIconByKind": true,
        "folderTapExpands": true,
        "statusColumn": "status",
        "statusOptions": ["active", "queued", "done"],
        "newFileLabel": "New task",
        "newFolderLabel": "New project",
        "tags": [
          { "column": "status", "colors": { "active": "green", "queued": "amber", "done": "gray" } }
        ],
        "scopeTargets": [
          { "table": "relations", "column": "fromId" }
        ],
        "detail": {
          "type": "column",
          "bindRow": true,
          "crossAxis": "stretch",
          "scroll": true,
          "children": [
            {
              "type": "record",
              "table": "entries",
              "compact": true,
              "readOnly": true,
              "fields": ["title", "status", "comment"]
            },
            {
              "type": "switch",
              "table": "entries",
              "column": "type",
              "cases": {
                "group": { "type": "column", "children": [] },
                "image": { "type": "column", "children": [] },
                "wireframe": { "type": "column", "children": [] },
                "sheets": { "type": "column", "children": [] },
                "docs": { "type": "column", "children": [] },
                "sketchpad": { "type": "column", "children": [] }
              },
              "default": {
                "type": "pick",
                "table": "entries",
                "column": "type",
                "label": "Turn this note into",
                "options": [
                  { "value": "note", "label": "Note" },
                  { "value": "image", "label": "Image" },
                  { "value": "docs", "label": "Doc" },
                  { "value": "sheets", "label": "Sheet" },
                  { "value": "wireframe", "label": "Wireframe" },
                  { "value": "sketchpad", "label": "Sketch" }
                ]
              }
            },
            {
              "type": "switch",
              "table": "entries",
              "column": "type",
              "cases": {
                "image":     { "type": "record", "table": "entries", "fields": ["attachment"], "editable": true },
                "wireframe": { "type": "embed", "table": "entries", "appletColumn": "type", "instanceFromRow": true, "screen": "solo", "height": 460 },
                "sheets":    { "type": "embed", "table": "entries", "appletColumn": "type", "instanceFromRow": true, "height": 460 },
                "docs":      { "type": "embed", "table": "entries", "appletColumn": "type", "instanceFromRow": true, "screen": "solo", "height": 460 },
                "sketchpad": { "type": "embed", "table": "entries", "appletColumn": "type", "instanceFromRow": true, "height": 460 }
              }
            },
            {
              "type": "text",
              "style": "caption",
              "value": "Log — this task's updates, notes and attachments, in order. Edit any entry in place, add one below, or drag a task in to nest it here (a task can live under more than one project)."
            },
            {
              "type": "entrythread",
              "table": "entries",
              "edgesTable": "relations",
              "edgeFrom": "fromId",
              "edgeTo": "toId",
              "edgeType": "type",
              "containsType": "contains",
              "titleColumn": "title",
              "subtitleColumn": "comment",
              "orderColumn": "order",
              "previewInline": true,
              "previewColumn": "attachment",
              "previewTypes": ["wireframe", "sheets", "docs", "sketchpad"],
              "appletColumn": "type",
              "peekHeight": 200,
              "editable": true,
              "allowAdd": true,
              "titleless": true,
              "timeColumn": "updatedAt",
              "addHint": "Write a comment…",
              "emptyText": "No log yet — write the first comment below, or attach a file with the paperclip.",
              "removeLabel": "Remove from this log",
              "authorColumn": "createdBy",
              "authorTable": "users",
              "authorNameColumn": "name",
              "attachInline": true,
              "attachColumn": "attachment",
              "action": { "fn": "editRow", "args": { "table": "entries" } }
            }
          ]
        }
      }
    },
    "people": {
      "title": "People",
      "body": {
        "type": "column",
        "crossAxis": "stretch",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Everyone on this board. Add a person below; tap one to rename. They show up as the 'created by' and 'prompting' chips on entries."
          },
          {
            "type": "composer",
            "table": "users",
            "column": "name",
            "placeholder": "Add a person by name…",
            "sendIcon": "person_add"
          },
          {
            "type": "cards",
            "table": "users",
            "height": "fill",
            "minCardWidth": 260,
            "title": "name",
            "tableView": false,
            "expandable": false,
            "action": { "fn": "editRow" }
          }
        ]
      }
    },
    "howto": {
      "title": "How dispatch works",
      "body": {
        "type": "column",
        "scroll": true,
        "children": [
          { "type": "text", "style": "title", "value": "Projects, tasks and logs" },
          { "type": "text", "value": "Dispatch tracks your team's work in three levels:\n\n• PROJECT — a folder of work. Projects can hold SUB-PROJECTS, so the left column is a directory you can expand like folders.\n• TASK — something to do inside a project (middle column).\n• LOG — a task's running conversation: comments, files and tools (right panel).\n\nTo use it: pick a project in the directory, pick a task in the middle, then read or add to its log on the right. The directory never shows log comments — those live with their task.\n\nA project travels: its ⋮ menu can EXPORT the whole project (sub-projects, tasks, logs and attachments) as one file, and IMPORT such a file into another project — or another device." },
          { "type": "text", "style": "title", "value": "Logs can hold more than text" },
          { "type": "text", "value": "A log entry is a COMMENT — no title, just what you want to say. Each one shows who wrote it and when. A comment can also carry attachments (use Attach on a comment, or the paperclip in the composer for a file-only entry), and a task's log can hold embedded tools:\n\n• Image — an image or file you can download or replace.\n• Wireframe / Sheet / Doc / Sketch — a little embedded tool with its OWN data, shown right in the log; press Expand to work on it full-size, Minimize to shrink it back.\n\nTap ⋮ on a comment to open its full details or remove it from the log." },
          { "type": "text", "style": "title", "value": "One task, more than one project" },
          { "type": "text", "value": "A task doesn't have to live in just one place. Drag a task onto another project to LINK it there too — it's the same task shown in both, so editing it once updates it everywhere. A little badge shows when a task lives in more than one project." }
        ]
      }
    }
  }
}
