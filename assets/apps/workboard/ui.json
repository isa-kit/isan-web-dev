                  "emptyActionLabel": "Add task",
                  "table": "tasks",
                  "filter": {
                    "column": "phase",
                    "value": "current"
                  },
                  "title": "title",
                  "subtitle": "detail",
                  "tags": [
                    {
                      "column": "track",
                      "colors": {
                        "engine": "blue",
                        "apps": "pink",
                        "sync": "teal",
                        "product": "green"
                      }
                    }
                  ],
                  "open": "Open task",
                  "action": {
                    "fn": "editRow"
                  }
                },
                {
                  "type": "text",
                  "value": "Needs your decision",
                  "style": "title"
                },
