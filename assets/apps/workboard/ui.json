                  "collapsible": true,
                  "recent": 50,
                  "expandable": true,
                  "expandFields": [
                    {
                      "column": "context",
                      "label": "Context"
                    },
                    {
                      "column": "completed",
                      "label": "Completed"
                    },
                    {
                      "column": "completedTime",
                      "label": "Time"
                    },
                    {
                      "column": "milestone",
                      "label": "Milestone"
                    },
                    {
                      "column": "units",
                      "label": "Units"
                    },
                    {
                      "column": "detail",
                      "label": "Detail"
                    }
                  ],
                  "open": "Open task",
                  "action": {
                    "fn": "editRow"
                  },
                  "search": true
                }
              ]
            }
          },
          {
            "label": "Stats",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "The board at a glance — work by phase, track, and priority."
                },
                {
                  "type": "row",
                  "wrap": true,
                  "children": [
                    {
                      "type": "stat",
                      "table": "tasks",
                      "filter": {
                        "column": "phase",
                        "value": "current"
                      },
                      "label": "In progress",
                      "color": "amber"
                    },
                    {
                      "type": "stat",
                      "table": "tasks",
                      "filter": {
                        "column": "phase",
                        "value": "future"
                      },
                      "label": "Queued",
                      "color": "blue"
                    },
                    {
                      "type": "stat",
                      "table": "tasks",
                      "filter": {
                        "column": "phase",
                        "value": "past"
                      },
                      "label": "Shipped",
                      "color": "green"
                    },
                    {
                      "type": "stat",
                      "table": "decisions",
                      "filter": {
                        "column": "status",
                        "value": "open"
                      },
                      "label": "Open questions",
                      "color": "coral"
                    }
                  ]
                },
                {
                  "type": "progress",
                  "table": "tasks",
                  "statusColumn": "phase",
                  "doneValue": "past",
                  "label": "Shipped",
                  "color": "green"
                },
                {
                  "type": "barchart",
                  "table": "tasks",
                  "groupColumn": "track",
                  "label": "Tasks per track",
                  "colors": {
                    "engine": "blue",
                    "apps": "pink",
                    "sync": "teal",
                    "product": "green"
                  }
                },
                {
                  "type": "piechart",
                  "table": "tasks",
                  "groupColumn": "priority",
                  "label": "Priority mix",
                  "height": 160,
                  "colors": {
                    "urgent": "red",
                    "high": "coral",
                    "normal": "blue",
                    "low": "gray"
                  }
                },
                {
                  "type": "barchart",
                  "table": "tasks",
                  "groupColumn": "milestone",
                  "label": "Tasks per milestone",
                  "limit": 8
                }
              ]
            }
          }
        ]
      }
