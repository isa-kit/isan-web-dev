                  "collapsible": true,
                  "recent": 5,
                  "expandFields": [
                    {
                      "column": "context",
                      "label": "Context"
                    },
                    {
                      "column": "phase",
                      "label": "Phase"
                    },
                    {
                      "column": "priority",
                      "label": "Priority"
                    },
                    {
                      "column": "milestone",
                      "label": "Milestone"
                    },
                    {
                      "column": "units",
                      "label": "Units"
                    },
                    {
                      "column": "labels",
                      "label": "Labels"
                    },
                    {
                      "column": "notes",
                      "label": "My notes"
                    }
                  ],
                  "open": "Open task",
                  "action": {
                    "fn": "editRow"
                  },
                  "filter": {
                    "column": "phase",
                    "in": [
                      "current",
                      "future"
                    ]
                  }
                }
              ]
            }
          },
          {
            "label": "Schedule",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "Tasks with a scheduled or due date, grouped by day. Set Scheduled (pending) or Due to see a task here."
                },
                {
                  "type": "row",
                  "wrap": true,
                  "children": [
                    {
                      "type": "button",
                      "label": "Incomplete",
                      "action": {
                        "fn": "setPresence",
                        "args": {
                          "table": "tasks",
                          "column": "completed",
                          "mode": "empty"
                        }
                      }
                    },
                    {
                      "type": "button",
                      "label": "Done",
                      "action": {
                        "fn": "setPresence",
                        "args": {
                          "table": "tasks",
                          "column": "completed",
                          "mode": "set"
                        }
                      }
                    },
                    {
                      "type": "button",
                      "label": "All",
                      "action": {
                        "fn": "setPresence",
                        "args": {
                          "table": "tasks",
                          "column": "completed",
                          "mode": ""
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "agenda",
                  "table": "tasks",
                  "filterable": true,
                  "dateColumns": [
                    "scheduledStart",
                    "due"
                  ],
                  "titleColumn": "title",
                  "statusColumn": "phase",
                  "doneValue": "past",
                  "action": {
                    "fn": "editRow"
                  }
                }
              ]
            }
          },
          {
            "label": "Sub-tasks",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "Parent/child task tree. Set a task's Parent to nest it (make a bigger task to house subtasks), or use + to add a subtask. Drag to nest/reorder; tap to open."
                },
                {
                  "type": "tree",
                  "table": "tasks",
                  "parentColumn": "parent",
                  "titleColumn": "title",
                  "statusColumn": "phase",
                  "doneValue": "past",
                  "onTap": {
                    "fn": "editRow"
                  },
                  "filterable": true,
                  "addChild": true,
                  "orderColumn": "order"
                }
              ]
            }
          },
