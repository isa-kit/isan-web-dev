                {
                  "type": "cards",
                  "table": "tasks",
                  "filter": {
                    "column": "completed",
                    "exists": true
                  },
                  "sort": {
                    "column": "completed",
                    "dir": "desc"
                  },
                  "title": "title",
                  "subtitle": "detail",
                  "tags": [
                    {
                      "column": "completed"
                    },
                    {
                      "column": "track",
                      "colors": {
                        "engine": "blue",
                        "apps": "pink",
                        "sync": "teal",
                        "product": "green"
                      }
                    }
