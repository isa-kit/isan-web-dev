                      }
                    }
                  ],
                  "open": "Open / answer",
                  "action": {
                    "fn": "editRow"
                  }
                }
              ]
            }
          },
          {
            "label": "Tasks",
            "child": {
              "type": "column",
              "children": [
                {
                  "type": "text",
                  "style": "caption",
                  "value": "Active work — current and upcoming. Search or group as needed."
                },
                {
                  "type": "button",
                  "label": "New task",
                  "icon": "add",
                  "action": {
                    "fn": "addRow",
                    "args": {
                      "table": "tasks",
                      "values": {
                        "phase": "future",
                        "priority": "normal"
