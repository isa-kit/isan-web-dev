                  "type": "cards",
                  "table": "tasks",
                  "filter": {
                    "column": "phase",
                    "value": "future"
                  },
                  "title": "title",
                  "subtitle": "detail",
                  "tags": [
                    {
                      "column": "track",
                      "colors": {
                        "engine": "blue",
                        "apps": "pink",
                        "sync": "teal",
                        "product": "green"
