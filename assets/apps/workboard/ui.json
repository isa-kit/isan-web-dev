                  "groupByOptions": [
                    {
                      "label": "Phase",
                      "column": "phase"
                    },
                    {
                      "label": "Priority",
                      "column": "priority"
                    },
                    {
                      "label": "Track",
                      "column": "track"
                    },
                    {
                      "label": "Project",
                      "column": "units"
                    }
                  ],
                  "title": "title",
                  "subtitle": "detail",
                  "tags": [
                    {
                      "column": "priority",
                      "colors": {
                        "urgent": "red",
                        "high": "amber",
                        "normal": "gray",
                        "low": "teal"
                      }
                    },
                    {
                      "column": "phase",
                      "colors": {
                        "future": "blue",
                        "current": "amber",
                        "past": "gray"
                      }
                    },
                    {
                      "column": "track",
                      "colors": {
                        "engine": "blue",
                        "apps": "pink",
                        "sync": "teal",
                        "product": "green"
                      }
                    }
