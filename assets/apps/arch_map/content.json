  "workflow": [
    {
      "id": "w1",
      "step": 1,
      "phase": "Plan",
      "title": "One task → many helpers",
      "detail": "An orchestrator splits the goal into independent pieces and hands each to its own AI agent — many run at the same time."
    },
    {
      "id": "w2",
      "step": 2,
      "phase": "Build",
      "title": "Each agent works in isolation",
      "detail": "Every agent takes a separate copy of the code so they never step on each other's work."
    },
    {
      "id": "w3",
      "step": 3,
      "phase": "Build",
      "title": "Small, scoped changes",
      "detail": "Work lands in small, reviewable steps instead of one big risky change."
    },
    {
      "id": "w4",
      "step": 4,
      "phase": "Ship",
      "title": "The gate",
      "detail": "Before anything can land it must pass automatic checks — code analysis plus the full test suite. A failure stops it cold."
    },
    {
      "id": "w5",
      "step": 5,
      "phase": "Ship",
      "title": "Merge to main",
      "detail": "Only work that passed the gate joins the app's main line."
    },
    {
      "id": "w6",
      "step": 6,
      "phase": "Ship",
      "title": "Auto-deploy",
      "detail": "A passing merge publishes to the live web app automatically — no manual step."
    },
    {
      "id": "w7",
      "step": 7,
      "phase": "Ship",
      "title": "Version stamp",
      "detail": "Each build records its date, time and id, so you can always see exactly what's live (Account → View app version)."
    }
  ],
  "updates": [
    {
      "id": "u1",
      "area": "Visibility",
      "title": "See your build",
      "detail": "A version stamp inside the app plus a freshness file on the live site, so you can tell at a glance when it last changed."
    },
    {
      "id": "u2",
      "area": "App",
      "title": "One tidy ⋮ menu",
      "detail": "The home-screen header collapsed into a single overflow menu — store, appearance, account, version, and more."
    },
    {
      "id": "u3",
      "area": "No-code",
      "title": "Action picker",
      "detail": "Set what a button does by picking from menus — no JSON. Chain several steps with ‘+ then’."
    },
    {
      "id": "u4",
      "area": "No-code",
      "title": "Automated rules (only if…)",
      "detail": "Make the app react: when a condition is true, do one thing (and optionally something else otherwise)."
    },
    {
      "id": "u5",
      "area": "No-code",
      "title": "Process templates",
      "detail": "Save a task and its sub-steps as a template; tap to stamp out a fresh copy into your tasks."
    },
    {
      "id": "u6",
      "area": "No-code",
      "title": "Visual condition builder",
      "detail": "Build the ‘when…’ part of a rule with field / is / value rows — and/or/not — no typing JSON."
    },
    {
      "id": "u7",
      "area": "Tasks",
      "title": "Recurring tasks",
      "detail": "Give a task a repeat (daily, weekly, monthly); completing it automatically creates the next one."
    },
    {
      "id": "u8",
      "area": "Tasks",
      "title": "Quick stage + undo",
      "detail": "Tap a task to move it To do → Doing → Done (it stamps the date), with an Undo button."
    },
    {
      "id": "u9",
      "area": "Sharing",
      "title": "Share by code or file",
      "detail": "Copy a whole app to your clipboard, or save it to a file — and paste/import it on another device."
    },
    {
      "id": "u10",
      "area": "Engine",
      "title": "New building blocks",
      "detail": "Reusable pieces added across apps: nested apps, a file explorer, compare & tier-list views, and more."
    }
  ]
